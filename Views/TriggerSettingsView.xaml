<UserControl x:Class="FACTOVA_Execute.Views.TriggerSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FACTOVA_Execute.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0056B3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15" Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <TextBlock Grid.Row="0" 
                   Text="{DynamicResource TriggerSettings_Title}" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Foreground="#212529"
                   Margin="0,0,0,15"/>

        <!-- 설정 내용 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White" 
                    BorderBrush="#DEE2E6" 
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="20">
                <StackPanel>
                    <!-- 안내 메시지 -->
                    <Border Background="#E7F3FF" 
                            BorderBrush="#B3D7FF"
                            BorderThickness="1"
                            Padding="15"
                            CornerRadius="3"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TriggerSettings_InfoTitle}" 
                                       FontWeight="Bold"
                                       Foreground="#004085"
                                       Margin="0,0,0,10"
                                       FontSize="14"/>
                            <TextBlock TextWrapping="Wrap" 
                                       Foreground="#004085"
                                       FontSize="13"
                                       Text="{DynamicResource TriggerSettings_InfoText}"/>
                        </StackPanel>
                    </Border>

                    <!-- 감시할 프로그램 목록 -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                   Text="{DynamicResource TriggerSettings_TargetProcess}" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Top"
                                   Margin="0,5,0,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBox x:Name="TargetProcessesTextBox"
                                     Height="100"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="5"/>
                            <TextBlock Text="{DynamicResource TriggerSettings_ProcessHint}" 
                                       FontSize="11" 
                                       Foreground="#6C757D"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- 체크 주기 -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                   Text="{DynamicResource TriggerSettings_CheckInterval}" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" 
                                 x:Name="CheckIntervalTextBox"
                                 Height="30"
                                 VerticalContentAlignment="Center"
                                 Padding="5"/>
                    </Grid>

                    <!-- 자동 실행 옵션 -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                   Text="{DynamicResource TriggerSettings_AutoRun}" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" 
                                  x:Name="AutoStartCheckBox"
                                  Content="{DynamicResource TriggerSettings_AutoRunDesc}"
                                  VerticalAlignment="Center"
                                  FontSize="13"/>
                    </Grid>

                    <!-- 설명 -->
                    <Border Background="#FFF3CD" 
                            BorderBrush="#FFE69C"
                            BorderThickness="1"
                            Padding="10"
                            CornerRadius="3"
                            Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TriggerSettings_HelpTitle}" 
                                       FontWeight="Bold"
                                       Foreground="#856404"
                                       Margin="0,0,0,5"/>
                            <TextBlock TextWrapping="Wrap" 
                                       Foreground="#856404"
                                       FontSize="12"
                                       Text="{DynamicResource TriggerSettings_HelpText}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- 버튼 영역 -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="SaveButton" 
                    Content="{DynamicResource Save}" 
                    Style="{StaticResource SaveButtonStyle}"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
