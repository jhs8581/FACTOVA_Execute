<UserControl x:Class="FACTOVA_Execute.Views.GeneralSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FACTOVA_Execute.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0056B3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15" Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <TextBlock Grid.Row="0" 
                   Text="{DynamicResource GeneralSettings_Title}" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Foreground="#212529"
                   Margin="0,0,0,15"/>

        <!-- 설정 내용 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White" 
                    BorderBrush="#DEE2E6" 
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="20">
                <StackPanel>
                <!-- 언어 설정 -->
                <Border BorderBrush="#DEE2E6" 
                        BorderThickness="0,0,0,1"
                        Padding="0,0,0,20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource GeneralSettings_Language}" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="#212529"
                                   Margin="0,0,0,10"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <RadioButton x:Name="KoreanRadio"
                                        Content="{DynamicResource GeneralSettings_LanguageKorean}"
                                        GroupName="Language"
                                        FontSize="14"
                                        Margin="0,0,20,0"
                                        Checked="LanguageRadio_Checked"/>
                            <RadioButton x:Name="EnglishRadio"
                                        Content="{DynamicResource GeneralSettings_LanguageEnglish}"
                                        GroupName="Language"
                                        FontSize="14"
                                        Checked="LanguageRadio_Checked"/>
                        </StackPanel>
                        
                        <TextBlock Text="{DynamicResource GeneralSettings_LanguageHint}" 
                                   FontSize="12" 
                                   Foreground="#6C757D"/>
                    </StackPanel>
                </Border>
                
                <!-- 연결 시 자동 실행 -->
                <Border BorderBrush="#DEE2E6" 
                        BorderThickness="0,0,0,1"
                        Padding="0,0,0,20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource GeneralSettings_AutoRun}" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="#212529"
                                   Margin="0,0,0,10"/>
                        
                        <CheckBox x:Name="AutoStartMonitoringCheckBox"
                                  FontSize="14"
                                  VerticalContentAlignment="Center">
                            <CheckBox.Content>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource GeneralSettings_AutoRunTitle}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{DynamicResource GeneralSettings_AutoRunDesc}" 
                                               FontSize="12" 
                                               Foreground="#6C757D"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </CheckBox.Content>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- 트레이로 실행 -->
                <Border BorderBrush="#DEE2E6" 
                        BorderThickness="0,0,0,1"
                        Padding="0,0,0,20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource GeneralSettings_RunMode}" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="#212529"
                                   Margin="0,0,0,10"/>
                        
                        <CheckBox x:Name="StartInTrayCheckBox"
                                  FontSize="14"
                                  VerticalContentAlignment="Center">
                            <CheckBox.Content>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource GeneralSettings_TrayRun}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{DynamicResource GeneralSettings_TrayRunDesc}" 
                                               FontSize="12" 
                                               Foreground="#6C757D"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </CheckBox.Content>
                        </CheckBox>

                        <Border Background="#FFF3CD" 
                                BorderBrush="#FFE69C"
                                BorderThickness="1"
                                Padding="10"
                                CornerRadius="3"
                                Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Warning}" 
                                           FontWeight="Bold"
                                           Foreground="#856404"
                                           Margin="0,0,0,5"/>
                                <TextBlock TextWrapping="Wrap" 
                                           Foreground="#856404"
                                           FontSize="12"
                                           Text="{DynamicResource GeneralSettings_RestartRequired}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 런처 설정 -->
                <Border BorderBrush="#DEE2E6" 
                        BorderThickness="0,0,0,1"
                        Padding="0,0,0,20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource GeneralSettings_Launcher}" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="#212529"
                                   Margin="0,0,0,15"/>
                        
                        <!-- 보기 모드 -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="{DynamicResource GeneralSettings_ViewMode}" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <RadioButton x:Name="GridViewRadio"
                                        Content="{DynamicResource GeneralSettings_ViewModeGrid}"
                                        GroupName="LauncherView"
                                        FontSize="13"
                                        Margin="0,0,0,5"/>
                            <RadioButton x:Name="GroupViewRadio"
                                        Content="{DynamicResource GeneralSettings_ViewModeGroup}"
                                        GroupName="LauncherView"
                                        FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" 
                                       FontSize="11" 
                                       Foreground="#6C757D"
                                       Margin="0,8,0,0"
                                       Text="{DynamicResource GeneralSettings_ViewModeDesc}"/>
                        </StackPanel>
                        
                        <!-- 행별 개수 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="{DynamicResource GeneralSettings_ItemsPerRow}" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBox x:Name="LauncherItemsPerRowTextBox"
                                     Width="60"
                                     Height="30"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     Padding="5,0"/>
                        </StackPanel>
                        
                        <TextBlock TextWrapping="Wrap" 
                                   FontSize="12" 
                                   Foreground="#6C757D"
                                   Text="{DynamicResource GeneralSettings_ItemsPerRowDesc}"/>
                    </StackPanel>
                </Border>

                <!-- 네트워크 상태 감지 설정 -->
                <Border Padding="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource GeneralSettings_NetworkMonitor}" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="#212529"
                                   Margin="0,0,0,10"/>
                        
                        <CheckBox x:Name="EnableNetworkMonitoringCheckBox"
                                  FontSize="14"
                                  VerticalContentAlignment="Center"
                                  Checked="EnableNetworkMonitoringCheckBox_Changed"
                                  Unchecked="EnableNetworkMonitoringCheckBox_Changed"
                                  Margin="0,0,0,15">
                            <CheckBox.Content>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource GeneralSettings_EnableNetworkMonitor}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{DynamicResource GeneralSettings_EnableNetworkMonitorDesc}" 
                                               FontSize="12" 
                                               Foreground="#6C757D"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </CheckBox.Content>
                        </CheckBox>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="{DynamicResource GeneralSettings_CheckInterval}" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBox x:Name="NetworkCheckIntervalTextBox"
                                     Width="60"
                                     Height="30"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     Padding="5,0"/>
                        </StackPanel>
                        
                        <TextBlock TextWrapping="Wrap" 
                                   FontSize="12" 
                                   Foreground="#6C757D"
                                   Margin="0,5,0,0"
                                   Text="{DynamicResource GeneralSettings_CheckIntervalDesc}"/>

                        <Border Background="#FFF3CD" 
                                BorderBrush="#FFE69C"
                                BorderThickness="1"
                                Padding="10"
                                CornerRadius="3"
                                Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource GeneralSettings_NetworkMonitorInfo}" 
                                           FontWeight="Bold"
                                           Foreground="#856404"
                                           Margin="0,0,0,5"/>
                                <TextBlock TextWrapping="Wrap" 
                                           Foreground="#856404"
                                           FontSize="12"
                                           Text="{DynamicResource GeneralSettings_NetworkMonitorInfoText}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
        </ScrollViewer>

        <!-- 저장 버튼 -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="SaveButton" 
                    Content="{DynamicResource Save}" 
                    Style="{StaticResource SaveButtonStyle}"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
