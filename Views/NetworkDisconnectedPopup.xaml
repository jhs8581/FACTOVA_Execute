<Window x:Class="FACTOVA_Execute.Views.NetworkDisconnectedPopup"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
mc:Ignorable="d"
Title="네트워크 연결 끊김" 
Height="280" Width="500"
WindowStartupLocation="CenterScreen"
ResizeMode="NoResize"
Topmost="True"
ShowInTaskbar="True"
WindowStyle="SingleBorderWindow"
Icon="/Icons/FACTOVA_Execute.ico">
    <Grid Background="#FFEBEE">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 경고 아이콘 및 메시지 -->
        <Border Grid.Row="0" 
                Background="#E53935"
                Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" 
                           FontSize="32"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>
                <TextBlock Text="네트워크 연결 끊김" 
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 메시지 내용 -->
        <Border Grid.Row="1" 
                Background="White"
                Padding="20">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="네트워크 연결이 끊어졌습니다. 확인하세요." 
                           FontSize="16"
                           TextWrapping="Wrap"
                           Foreground="#212529"
                           Margin="0,0,0,20"/>
                
                <Border BorderBrush="#DEE2E6"
                        BorderThickness="1"
                        Background="#F8F9FA"
                        Padding="15"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="끊어진 시간:" 
                                   FontSize="13"
                                   Foreground="#6C757D"
                                   Margin="0,0,0,5"/>
                        <TextBlock x:Name="DisconnectedTimeTextBlock" 
                                   Text="00:00:00.000"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="#E53935"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
