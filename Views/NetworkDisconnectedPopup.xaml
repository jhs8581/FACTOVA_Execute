<Window x:Class="FACTOVA_Execute.Views.NetworkDisconnectedPopup"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
mc:Ignorable="d"
Title="{DynamicResource NetworkPopup_Title}" 
Height="500" Width="520"
WindowStartupLocation="CenterScreen"
ResizeMode="NoResize"
Topmost="True"
ShowInTaskbar="True"
WindowStyle="SingleBorderWindow"
Icon="/Icons/FACTOVA_Execute.ico">
    <Grid Background="#FFEBEE">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 경고 아이콘 및 메시지 -->
        <Border Grid.Row="0" 
                Background="#E53935"
                Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" 
                           FontSize="32"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>
                <TextBlock Text="{DynamicResource NetworkPopup_Title}" 
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 메시지 내용 -->
        <Border Grid.Row="1" 
                Background="White"
                Padding="20">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="{DynamicResource NetworkPopup_Message}" 
                           FontSize="16"
                           TextWrapping="Wrap"
                           Foreground="#212529"
                           Margin="0,0,0,15"/>
                
                <!-- 끊김 시작 시간 -->
                <Border BorderBrush="#DEE2E6"
                        BorderThickness="1"
                        Background="#F8F9FA"
                        Padding="12"
                        CornerRadius="4"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource NetworkPopup_StartTime}" 
                                   FontSize="13"
                                   Foreground="#6C757D"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBlock x:Name="StartTimeTextBlock" 
                                   Grid.Column="1"
                                   Text="2024-01-01 00:00:00"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   FontFamily="Consolas"
                                   Foreground="#495057"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                
                <!-- 경과 시간 -->
                <Border BorderBrush="#E53935"
                        BorderThickness="2"
                        Background="#FFEBEE"
                        Padding="15"
                        CornerRadius="4"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource NetworkPopup_ElapsedTime}" 
                                   FontSize="13"
                                   Foreground="#6C757D"
                                   Margin="0,0,0,5"/>
                        <TextBlock x:Name="DisconnectedTimeTextBlock" 
                                   Text="00:00:00"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="#E53935"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <!-- 점검 중인 네트워크 -->
                <Border BorderBrush="#DEE2E6"
                        BorderThickness="1"
                        Background="#F8F9FA"
                        Padding="12"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource NetworkPopup_CheckingNetwork}" 
                                   FontSize="13"
                                   Foreground="#6C757D"
                                   Margin="0,0,0,5"/>
                        <TextBlock x:Name="CheckingAddressTextBlock" 
                                   Text="{DynamicResource NetworkPopup_Checking}"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   Foreground="#495057"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
